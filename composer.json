{
    "name": "devletes/filament-progress-bar",
    "description": "Reusable progress bar components for Filament 5 tables and infolists.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "filament",
        "filament-plugin",
        "laravel",
        "progress",
        "progress-bar",
        "table-column",
        "infolist"
    ],
    "authors": [
        {
            "name": "Devletes",
            "email": "packages@devletes.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Devletes\\FilamentProgressBar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devletes\\FilamentProgressBar\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "filament-assets": "@php vendor/orchestra/testbench-core/laravel/artisan filament:assets --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@filament-assets",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devletes\\FilamentProgressBar\\ProgressBarServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "homepage": "https://github.com/devletes/filament-progress-bar",
    "support": {
        "issues": "https://github.com/devletes/filament-progress-bar/issues",
        "source": "https://github.com/devletes/filament-progress-bar"
    }
}
